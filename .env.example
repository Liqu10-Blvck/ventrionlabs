# Base URL del Public Landing API (producción)
# Ejemplo: https://api.tu-dominio.com
PUBLIC_LANDING_API_BASE_URL=

# URL pública del sitio (para sitemap y canonical)
# Ejemplo: https://ventrionlabs.cl
SITE_URL=

# Google Search Console (meta verification)
# Valor: el token que te entrega Google
GOOGLE_SITE_VERIFICATION=

# Email transaccional para el formulario de contacto
# Temporalmente puedes usar tu correo personal como destino final
RESEND_API_KEY=
CONTACT_TO_EMAIL=
# Mientras no tengas dominio, puedes usar el remitente de prueba de Resend
# Ejemplo: Ventrion Labs <onboarding@resend.dev>
CONTACT_FROM_EMAIL=

# Opcional: fallback local de códigos si /api/public/products no está disponible
# PUBLIC_LANDING_PRODUCT_CODES=demo
