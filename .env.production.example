# Production Environment Variables
# Copy this file to .env.production for production builds

# Base URL del Public Landing API (producción)
PUBLIC_LANDING_API_BASE_URL=https://api.ventrionlabs.cl

# URL pública del sitio (para sitemap y canonical)
SITE_URL=https://ventrionlabs.cl

# Google Search Console (meta verification)
GOOGLE_SITE_VERIFICATION=your_google_verification_token_here

# Email transaccional para el formulario de contacto
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=contacto@ventrionlabs.cl
CONTACT_FROM_EMAIL=Ventrion Labs <contacto@ventrionlabs.cl>

# Opcional: fallback local de códigos si /api/public/products no está disponible
# PUBLIC_LANDING_PRODUCT_CODES=demo
